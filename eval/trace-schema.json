{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Dev Harness Evaluation Trace",
  "description": "每次评测运行的结构化执行轨迹，供 Meta-Harness 外循环消费",
  "type": "object",
  "required": ["meta", "result"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["task_id", "config", "model", "timestamp"],
      "properties": {
        "task_id": {"type": "string", "description": "任务标识 (如 swe-bench-lite-001)"},
        "task_source": {"type": "string", "enum": ["swe-bench-lite", "swe-bench-verified", "real-task", "custom"]},
        "config": {"type": "string", "enum": ["full", "no-stophook", "no-skill-resolve", "no-gate", "no-audit", "bare"]},
        "ide": {"type": "string", "enum": ["claude-code", "cursor", "other"]},
        "model": {"type": "string", "description": "模型标识 (如 claude-sonnet-4-6)"},
        "timestamp": {"type": "string", "format": "date-time"},
        "harness_version": {"type": "string"}
      }
    },
    "result": {
      "type": "object",
      "properties": {
        "pass": {"type": "boolean", "description": "任务是否通过 (SWE-bench: 测试通过; 真实任务: build+test 通过)"},
        "build_pass": {"type": "boolean"},
        "test_pass": {"type": "boolean"},
        "tokens_total": {"type": "integer"},
        "time_total_sec": {"type": "number"},
        "human_interventions": {"type": "integer", "description": "人工干预次数"},
        "stop_hook_triggers": {"type": "integer", "description": "Stop Hook 触发次数"},
        "auto_continues": {"type": "integer", "description": "自动续跑次数"}
      }
    },
    "stages": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {"type": "string"},
          "skill_resolved": {"type": "string", "description": "Skill 解析结果 (如 L2:create_plan)"},
          "duration_sec": {"type": "number"},
          "tokens": {"type": "integer"},
          "output_summary": {"type": "string", "maxLength": 500},
          "phases": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {"type": "string"},
                "status": {"type": "string"},
                "gates": {"type": "object"},
                "retries": {"type": "integer"},
                "error": {"type": "string"},
                "fix_applied": {"type": "string"}
              }
            }
          }
        }
      }
    },
    "judge": {
      "type": "object",
      "description": "LLM-as-Judge 评分 (Task Set B 专用)",
      "properties": {
        "model": {"type": "string"},
        "scores": {
          "type": "object",
          "properties": {
            "completeness": {"type": "number", "minimum": 1, "maximum": 10},
            "code_quality": {"type": "number", "minimum": 1, "maximum": 10},
            "architecture": {"type": "number", "minimum": 1, "maximum": 10},
            "test_coverage": {"type": "number", "minimum": 1, "maximum": 10},
            "robustness": {"type": "number", "minimum": 1, "maximum": 10}
          }
        },
        "pairwise_vs_bare": {"type": "string", "enum": ["harness", "bare", "tie"]},
        "reasoning": {"type": "string"}
      }
    }
  }
}
